# Copiar en el VPS como .env (no se sube por rsync):
#   cp ops/.env.hostinger.example .env
#   nano .env
#   php artisan key:generate

APP_NAME="PetFlow API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://srv1197160.hstgr.cloud

APP_LOCALE=es
