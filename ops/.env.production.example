APP_NAME="SmartPet API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.petflow.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=petflow
DB_USERNAME=petflow
DB_PASSWORD=CHANGE_ME

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=database

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=petflow.com,www.petflow.com,api.petflow.com
SANCTUM_EXPIRATION=1440

# Billing/DIAN (stub en staging)
DIAN_STUB_MODE=accepted

